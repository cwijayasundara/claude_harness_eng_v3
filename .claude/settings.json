{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(npm test:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run typecheck:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsc:*)",
      "Bash(docker compose:*)",
      "Bash(curl localhost:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(mkdir:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scope-directory.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/protect-env.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/detect-secrets.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/lint-on-save.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": ".claude/hooks/typecheck.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-architecture.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-function-length.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-file-length.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-gate.sh",
            "timeout": 30000
          },
          {
            "type": "command",
            "command": ".claude/hooks/sprint-contract-gate.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/task-completed.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/teammate-idle-check.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
